# ==============================================
# Plataforma de Comissionamento Vital - ENV
# ==============================================
# Template de variáveis de ambiente.
# Copie este arquivo para .env e preencha os valores reais.

# ----------------------------------------------
# BANCO DE DADOS (OBRIGATÓRIO)
# ----------------------------------------------
DATABASE_URL=mysql://usuario:senha@host:3306/vital_comissoes

# ----------------------------------------------
# AUTENTICAÇÃO JWT (OBRIGATÓRIO)
# ----------------------------------------------
JWT_SECRET=troque-por-um-segredo-forte

# ----------------------------------------------
# AMBIENTE
# ----------------------------------------------
NODE_ENV=development
PORT=3000

# ----------------------------------------------
# APP (FRONTEND)
# ----------------------------------------------
VITE_APP_TITLE=Plataforma de Comissionamento Vital

# ----------------------------------------------
# OAUTH (OPCIONAL)
# ----------------------------------------------
# VITE_APP_ID=
# VITE_OAUTH_PORTAL_URL=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=

# ----------------------------------------------
# NOTIFICAÇÃO OWNER (OPCIONAL - Manus Forge)
# ----------------------------------------------
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# ----------------------------------------------
# EMAIL SMTP (OPCIONAL)
# ----------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_NAME=Sua Saúde Vital

